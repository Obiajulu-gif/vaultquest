# Soroban deployment environment variables
# Copy this file to contracts/.env and fill in real values for your environment.

# Environment selector: local, testnet, production
SOROBAN_ENV=local

# RPC endpoints and network passphrases
SOROBAN_RPC_URL_LOCAL=http://127.0.0.1:8000
SOROBAN_NETWORK_PASSPHRASE_LOCAL=Localhost Network

SOROBAN_RPC_URL_TESTNET=https://rpc.testnet.soroban.stellar.org
SOROBAN_NETWORK_PASSPHRASE_TESTNET=Test SDF Network ; September 2022

# Admin/deployer account
DRIP_POOL_ADMIN_ADDRESS=G...YOUR_ADMIN_ADDRESS...
DRIP_POOL_ADMIN_SECRET=SC...YOUR_ADMIN_SECRET...

# Contract outputs
DRIP_POOL_WASM_PATH=./drip-pool/target/wasm32-unknown-unknown/release/drip_pool.wasm
DRIP_POOL_CONTRACT_ID=
