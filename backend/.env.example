# Action ledger (issue #34)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vaultquest
INTERNAL_SERVICE_SECRET=change-me-to-a-long-random-string
# Replace the placeholder secret with a strong, unique value. The backend rejects placeholder values at boot.
ORPHAN_TTL_MINUTES=10
LOG_LEVEL=info
PORT=3001
NODE_ENV=development
# Rate limiting (per wallet or IP)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
